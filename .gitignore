# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# PRD
prd.md

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Workspace packages — ignore build artifacts and nested deps
packages/**/node_modules
packages/**/dist
packages/**/*.tsbuildinfo
packages/**/out
packages/renderer/test-results

# testing
/coverage
/playwright-report
/test-results

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# Database
*.db
*.db-journal
.env*.local
