{
  "name": "le-relief",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "seed": "npx tsx scripts/seed.ts",
    "qa:translations": "npx tsx scripts/translation-qa.ts",
    "renderer:build": "pnpm --filter @le-relief/types build && pnpm --filter @le-relief/renderer build",
    "renderer:typecheck": "pnpm --filter @le-relief/types typecheck && pnpm --filter @le-relief/renderer typecheck",
    "renderer:test": "pnpm --filter @le-relief/renderer test",
    "renderer:smoke": "pnpm --filter @le-relief/renderer smoke"
  },
  "dependencies": {
    "@le-relief/renderer": "workspace:*",
    "@le-relief/types": "workspace:*",
    "@opentelemetry/api": "^1.9.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/extension-character-count": "^3.22.4",
    "@tiptap/extension-code-block-lowlight": "^3.22.4",
    "@tiptap/extension-highlight": "^3.22.4",
    "@tiptap/extension-image": "^3.22.4",
    "@tiptap/extension-link": "^3.22.4",
    "@tiptap/extension-placeholder": "^3.22.4",
    "@tiptap/extension-underline": "^3.22.4",
    "@tiptap/pm": "^3.22.4",
    "@tiptap/react": "^3.22.4",
    "@tiptap/starter-kit": "^3.22.4",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.2",
    "firebase-admin": "^13.8.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.12.0",
    "slugify": "^1.6.9",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
