{
  "buildCommand": "pnpm renderer:build && next build --webpack",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/publish-scheduled",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/social-scheduler",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/wp-sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/translate-published-fr",
      "schedule": "*/5 * * * *"
    }
  ]
}
